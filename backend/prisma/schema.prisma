/// Central operational domain. A field service (atendimento) is the foundation
/// reused by every produced document (OS, PMOC, Laudo, Relatório, Orçamento,
/// Recibo). Each Work Order goes through exactly one Operation.
model Operation {
  id                              String                              @id @default(uuid()) @db.Uuid
  number                          Int                                 @unique @default(autoincrement())
  customerId                      String                              @map("customer_id") @db.Uuid
  addressId                       String?                             @map("address_id") @db.Uuid
  equipmentId                     String?                             @map("equipment_id") @db.Uuid
  operatorId                      String                              @map("operator_id") @db.Uuid
  type                            OperationType
  requestedDocumentType           DocumentTemplateType                @default(WORK_ORDER) @map("requested_document_type")
  serviceTypes                    OperationType[]                     @default([]) @map("service_types")
  status                          OperationStatus                     @default(DRAFT)
  scheduledFor                    DateTime?                           @map("scheduled_for") @db.Timestamptz(3)
  startedAt                       DateTime?                           @map("started_at") @db.Timestamptz(3)
  completedAt                     DateTime?                           @map("completed_at") @db.Timestamptz(3)
  checklist                       Json                                @default("[]")
  observations                    String?                             @db.Text
  reportedIssue                   String?                             @map("reported_issue") @db.Text
  serviceDescription              String?                             @map("service_description") @db.Text
  receiptNumber                   String?                             @map("receipt_number") @db.VarChar(40)
  receiptIssuedAt                 DateTime?                           @map("receipt_issued_at") @db.Date
  receiptAmount                   Decimal?                            @map("receipt_amount") @db.Decimal(15, 2)
  receiptAmountInWords            String?                             @map("receipt_amount_in_words") @db.VarChar(500)
  receiptService                  String?                             @map("receipt_service") @db.VarChar(500)
  receiptDescription              String?                             @map("receipt_description") @db.Text
  receiptWarrantyDays             Int?                                @map("receipt_warranty_days")
  receiptDeclaration              String?                             @map("receipt_declaration") @db.Text
  technicalDiagnosis              String?                             @map("technical_diagnosis") @db.Text
  technicalRecommendations        String?                             @map("technical_recommendations") @db.Text
  technicalOpinionObjective       String?                             @map("technical_opinion_objective") @db.Text
  technicalOpinionObjectiveItems  String[]                            @default([]) @map("technical_opinion_objective_items")
  technicalOpinionConditions      String?                             @map("technical_opinion_conditions") @db.Text
  technicalOpinionAnalysis        String?                             @map("technical_opinion_analysis") @db.Text
  technicalOpinionConclusion      String?                             @map("technical_opinion_conclusion") @db.Text
  technicalOpinionConclusionItems String[]                            @default([]) @map("technical_opinion_conclusion_items")
  technicalOpinionRecommendations String?                             @map("technical_opinion_recommendations") @db.Text
  technicalOpinionResponsible     String?                             @map("technical_opinion_responsible") @db.VarChar(180)
  technicalOpinionCrea            String?                             @map("technical_opinion_crea") @db.VarChar(100)
  referenceMonth                  Int?                                @map("reference_month") @db.SmallInt
  referenceYear                   Int?                                @map("reference_year") @db.SmallInt
  maintenanceType                 OperationMaintenanceType?           @map("maintenance_type")
  signatureData                   String?                             @map("signature_data") @db.Text
  customerSignerName              String?                             @map("customer_signer_name") @db.VarChar(180)
  customerSignerRole              String?                             @map("customer_signer_role") @db.VarChar(120)
  signedAt                        DateTime?                           @map("signed_at") @db.Timestamptz(3)
  createdAt                       DateTime                            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                       DateTime                            @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer                        Customer                            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address                         CustomerAddress?                    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  equipment                       Equipment?                          @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  operator                        User                                @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  photos                          OperationPhoto[]
  documents                       OperationDocument[]
  assignment                      Assignment?
  assignmentHistory               AssignmentHistory[]
  lifecycleEvents                 AssetLifecycleEvent[]
  maintenanceExecution            MaintenanceExecution?
  pmocExecutionRequest            PmocExecutionRequest?
  generatedPmocExecutionRequest   PmocExecutionRequest?               @relation("PmocGeneratedOperation")
  pmocHistoryEvents               PmocHistory[]
  parts                           OperationPart[]
  stockMovements                  StockMovement[]
  budgets                         Budget[]
  maintenanceChecklistItems       OperationMaintenanceChecklistItem[]
  inspectedEquipments             OperationInspectedEquipment[]
  sourceSaleId                    String?                             @map("source_sale_id") @db.Uuid
  sourceSale                      Sale?                               @relation(fields: [sourceSaleId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([equipmentId, createdAt])
  @@index([operatorId, createdAt])
  @@index([requestedDocumentType, status, createdAt], map: "operations_requested_document_status_idx")
  @@index([status, createdAt])
  @@index([scheduledFor, status], map: "operations_schedule_status_idx")
  @@index([sourceSaleId])
  @@map("operations")
}

