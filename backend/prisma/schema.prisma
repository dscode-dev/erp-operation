  product            Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([organizationId, active])
  @@index([productId, active, validFrom])
  @@index([productId, validFrom, validUntil])
  @@index([validUntil])
  @@map("product_pricings")
}

model Budget {
  id                String                @id @default(uuid()) @db.Uuid
  organizationId    String                @map("organization_id") @db.Uuid
  operationId       String?               @map("operation_id") @db.Uuid
  customerId        String                @map("customer_id") @db.Uuid
  customerAddressId String?               @map("customer_address_id") @db.Uuid
  equipmentId       String?               @map("equipment_id") @db.Uuid
  number            Int                   @unique @default(autoincrement())
  status            BudgetStatus          @default(DRAFT)
  title             String                @db.VarChar(180)
  description       String?               @db.Text
  issuedAt          DateTime              @default(now()) @map("issued_at") @db.Timestamptz(3)
  introduction      String                @db.Text
  serviceSubtotal   Decimal               @default(0) @map("service_subtotal") @db.Decimal(14, 2)
  materialSubtotal  Decimal               @default(0) @map("material_subtotal") @db.Decimal(14, 2)
  subtotal          Decimal               @default(0) @db.Decimal(14, 2)
  discount          Decimal               @default(0) @db.Decimal(14, 2)
  additional        Decimal               @default(0) @db.Decimal(14, 2)
  total             Decimal               @default(0) @db.Decimal(14, 2)
  amountInWords     String                @map("amount_in_words") @db.VarChar(500)
  validityDays      Int                   @default(30) @map("validity_days")
  paymentMethods    BudgetPaymentMethod[] @default([]) @map("payment_methods")
  commercialNotes   String?               @map("commercial_notes") @db.Text
  expirationDate    DateTime              @map("expiration_date") @db.Timestamptz(3)
  observations      String?               @db.Text
  createdBy         String                @map("created_by") @db.Uuid
  approvedAt        DateTime?             @map("approved_at") @db.Timestamptz(3)
  rejectedAt        DateTime?             @map("rejected_at") @db.Timestamptz(3)
  canceledAt        DateTime?             @map("canceled_at") @db.Timestamptz(3)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  operation         Operation?            @relation(fields: [operationId], references: [id], onDelete: SetNull)
  customer          Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerAddress   CustomerAddress?      @relation(fields: [customerAddressId], references: [id], onDelete: SetNull)
  equipment         Equipment?            @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  creator           User                  @relation("BudgetCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  items             BudgetItem[]
  approvals         BudgetApproval[]
  history           BudgetHistory[]
  document          OperationDocument?

  @@index([organizationId, status, createdAt])
  @@index([operationId, status])
  @@index([customerId, createdAt])
  @@index([equipmentId, createdAt])
  @@index([expirationDate])
  @@map("budgets")
}

model BudgetItem {
  id                String         @id @default(uuid()) @db.Uuid
  budgetId          String         @map("budget_id") @db.Uuid
  productId         String?        @map("product_id") @db.Uuid
  type              BudgetItemType @default(MATERIAL)
  description       String         @db.Text
  quantity          Decimal        @db.Decimal(12, 3)
  unit              String         @db.VarChar(20)
  unitPrice         Decimal        @map("unit_price") @db.Decimal(14, 2)
  sortOrder         Int            @default(0) @map("sort_order")
  snapshotCost      Decimal        @map("snapshot_cost") @db.Decimal(14, 2)
  snapshotSalePrice Decimal        @map("snapshot_sale_price") @db.Decimal(14, 2)
  snapshotMargin    Decimal        @map("snapshot_margin") @db.Decimal(7, 2)
  total             Decimal        @db.Decimal(14, 2)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  budget            Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  product           Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([budgetId])
  @@index([budgetId, type, sortOrder])
  @@index([productId])
  @@map("budget_items")
}

model BudgetApproval {
  id          String       @id @default(uuid()) @db.Uuid
  budgetId    String       @map("budget_id") @db.Uuid
  actorId     String       @map("actor_id") @db.Uuid
  status      BudgetStatus
  observation String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  budget      Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  actor       User         @relation("BudgetApprovalActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([budgetId, createdAt])
  @@index([actorId, createdAt])
  @@map("budget_approvals")
}

model BudgetHistory {
  id             String              @id @default(uuid()) @db.Uuid
  budgetId       String              @map("budget_id") @db.Uuid
  actorId        String              @map("actor_id") @db.Uuid
  action         BudgetHistoryAction
  previousStatus BudgetStatus?       @map("previous_status")
  newStatus      BudgetStatus        @map("new_status")
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  budget         Budget              @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  actor          User                @relation("BudgetHistoryActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([budgetId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("budget_history")
}

model FinancialAccount {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  name           String               @db.VarChar(140)
  type           FinancialAccountType
  description    String?              @db.Text
  openingBalance Decimal              @default(0) @map("opening_balance") @db.Decimal(14, 2)
  currentBalance Decimal              @default(0) @map("current_balance") @db.Decimal(14, 2)
  active         Boolean              @default(true)
  deletedAt      DateTime?            @map("deleted_at") @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  entries        FinancialEntry[]

  @@index([organizationId, active])
  @@index([type, active])
  @@map("financial_accounts")
}

model FinancialCategory {
  id             String                     @id @default(uuid()) @db.Uuid
  organizationId String                     @map("organization_id") @db.Uuid
  name           String                     @db.VarChar(140)
  type           FinancialCategoryType
  color          String?                    @db.VarChar(20)
  icon           String?                    @db.VarChar(80)
  active         Boolean                    @default(true)
  deletedAt      DateTime?                  @map("deleted_at") @db.Timestamptz(3)
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  entries        FinancialEntry[]
  allocations    FinancialEntryAllocation[]

  @@index([organizationId, type, active])
  @@index([name])
  @@map("financial_categories")
}

model FinancialEntry {
  id             String                     @id @default(uuid()) @db.Uuid
  organizationId String                     @map("organization_id") @db.Uuid
  accountId      String                     @map("account_id") @db.Uuid
  categoryId     String                     @map("category_id") @db.Uuid
  type           FinancialEntryType
  origin         FinancialEntryOrigin       @default(MANUAL)
  originId       String?                    @map("origin_id") @db.Uuid
  amount         Decimal                    @db.Decimal(14, 2)
  dueDate        DateTime                   @map("due_date") @db.Timestamptz(3)
  paidAt         DateTime?                  @map("paid_at") @db.Timestamptz(3)
  description    String                     @db.VarChar(180)
  notes          String?                    @db.Text
  status         FinancialEntryStatus       @default(PENDING)
  createdBy      String                     @map("created_by") @db.Uuid
  canceledAt     DateTime?                  @map("canceled_at") @db.Timestamptz(3)
  deletedAt      DateTime?                  @map("deleted_at") @db.Timestamptz(3)
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  account        FinancialAccount           @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category       FinancialCategory          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  creator        User                       @relation("FinancialEntryCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  allocations    FinancialEntryAllocation[]
  history        FinancialHistory[]

  @@index([organizationId, status, dueDate])
  @@index([accountId, status, dueDate])
  @@index([categoryId, dueDate])
  @@index([type, status, dueDate])
  @@index([origin, originId])
  @@index([createdBy, createdAt])
  @@map("financial_entries")
}

model FinancialEntryAllocation {
  id         String            @id @default(uuid()) @db.Uuid
  entryId    String            @map("entry_id") @db.Uuid
  categoryId String            @map("category_id") @db.Uuid
  amount     Decimal           @db.Decimal(14, 2)
  notes      String?           @db.Text
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  entry      FinancialEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  category   FinancialCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([entryId])
  @@index([categoryId])
  @@map("financial_entry_allocations")
}

model FinancialHistory {
  id             String                 @id @default(uuid()) @db.Uuid
  entryId        String                 @map("entry_id") @db.Uuid
  actorId        String                 @map("actor_id") @db.Uuid
  action         FinancialHistoryAction
  previousStatus FinancialEntryStatus?  @map("previous_status")
  newStatus      FinancialEntryStatus   @map("new_status")
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  entry          FinancialEntry         @relation(fields: [entryId], references: [id], onDelete: Cascade)
  actor          User                   @relation("FinancialHistoryActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entryId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("financial_history")
}

model PurchaseOrder {
  id               String              @id @default(uuid()) @db.Uuid
  organizationId   String              @map("organization_id") @db.Uuid
  supplierId       String              @map("supplier_id") @db.Uuid
  number           Int                 @unique @default(autoincrement())
  status           PurchaseOrderStatus @default(DRAFT)
  notes            String?             @db.Text
  expectedDelivery DateTime?           @map("expected_delivery") @db.Timestamptz(3)
  createdBy        String              @map("created_by") @db.Uuid
  canceledAt       DateTime?           @map("canceled_at") @db.Timestamptz(3)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  supplier         Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  creator          User                @relation("PurchaseOrderCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  items            PurchaseOrderItem[]
  receipts         PurchaseReceipt[]
  history          PurchaseHistory[]

  @@index([organizationId, status, createdAt])
  @@index([supplierId, createdAt])
  @@index([expectedDelivery])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                  String        @id @default(uuid()) @db.Uuid
  purchaseOrderId     String        @map("purchase_order_id") @db.Uuid
  productId           String        @map("product_id") @db.Uuid
  quantity            Decimal       @db.Decimal(12, 3)
  unit                String        @db.VarChar(20)
  snapshotCost        Decimal       @map("snapshot_cost") @db.Decimal(14, 2)
  snapshotDescription String        @map("snapshot_description") @db.Text
  receivedQuantity    Decimal       @default(0) @map("received_quantity") @db.Decimal(12, 3)
  deletedAt           DateTime?     @map("deleted_at") @db.Timestamptz(3)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  purchaseOrder       PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product             Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId, deletedAt])
  @@index([productId])
  @@map("purchase_order_items")
}

model PurchaseReceipt {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  receivedBy      String        @map("received_by") @db.Uuid
  receivedAt      DateTime      @map("received_at") @db.Timestamptz(3)
  notes           String?       @db.Text
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receiver        User          @relation("PurchaseReceiptReceivedBy", fields: [receivedBy], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId, receivedAt])
  @@index([receivedBy, receivedAt])
  @@map("purchase_receipts")
}

model PurchaseHistory {
  id              String                @id @default(uuid()) @db.Uuid
  purchaseOrderId String                @map("purchase_order_id") @db.Uuid
  actorId         String                @map("actor_id") @db.Uuid
  action          PurchaseHistoryAction
  previousStatus  PurchaseOrderStatus?  @map("previous_status")
  newStatus       PurchaseOrderStatus   @map("new_status")
  metadata        Json                  @default("{}")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  actor           User                  @relation("PurchaseHistoryActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("purchase_history")
}
