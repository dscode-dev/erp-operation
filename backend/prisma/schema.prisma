  INFO
  SUCCESS
  WARNING
  DANGER
}

enum NotificationEntityType {
  ASSIGNMENT
  OPERATION
  BUDGET
  MAINTENANCE
  PMOC
  DOCUMENT
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(150)
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("system_settings")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String   @db.VarChar(100)
  resource  String   @db.VarChar(150)
  actor     String?  @db.VarChar(255)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([resource, createdAt])
  @@index([actor, createdAt])
  @@map("audit_logs")
}

model User {
  id                       String                 @id @default(uuid()) @db.Uuid
  email                    String                 @unique @db.VarChar(254)
  username                 String                 @unique @db.VarChar(50)
  name                     String                 @db.VarChar(150)
  passwordHash             String                 @map("password_hash") @db.VarChar(255)
  role                     Role
  avatarAssetId            String?                @unique @map("avatar_asset_id") @db.Uuid
  phone                    String?                @db.VarChar(30)
  jobTitle                 String?                @map("job_title") @db.VarChar(100)
  notes                    String?                @db.Text
  mustChangePassword       Boolean                @default(false) @map("must_change_password")
  isActive                 Boolean                @default(true) @map("is_active")
  disabledAt               DateTime?              @map("disabled_at") @db.Timestamptz(3)
  lastLoginAt              DateTime?              @map("last_login_at") @db.Timestamptz(3)
  createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  refreshTokens            RefreshToken[]
  preferences              UserPreferences?
  permission               UserPermission?
  avatarAsset              UserAvatarAsset?       @relation(fields: [avatarAssetId], references: [id], onDelete: SetNull)
  operations               Operation[]
  assignmentsCreated       Assignment[]           @relation("AssignmentAssignedBy")
  assignmentsReceived      Assignment[]           @relation("AssignmentAssignedTo")
  assignmentEvents         AssignmentHistory[]    @relation("AssignmentHistoryActor")
  assetLifecycleEvents     AssetLifecycleEvent[]
  maintenancePlans         MaintenancePlan[]
  stockMovements           StockMovement[]
  budgetsCreated           Budget[]               @relation("BudgetCreatedBy")
  budgetApprovals          BudgetApproval[]       @relation("BudgetApprovalActor")
  budgetHistoryEvents      BudgetHistory[]        @relation("BudgetHistoryActor")
  financialEntriesCreated  FinancialEntry[]       @relation("FinancialEntryCreatedBy")
  financialHistoryEvents   FinancialHistory[]     @relation("FinancialHistoryActor")
  purchaseOrdersCreated    PurchaseOrder[]        @relation("PurchaseOrderCreatedBy")
  purchaseReceiptsReceived PurchaseReceipt[]      @relation("PurchaseReceiptReceivedBy")
  purchaseHistoryEvents    PurchaseHistory[]      @relation("PurchaseHistoryActor")
  notifications            Notification[]         @relation("NotificationRecipient")
  pmocDefaultOperatorFor   PmocPlan[]             @relation("PmocDefaultOperator")
  pmocDefaultTechnicianFor PmocPlan[]             @relation("PmocDefaultTechnician")
  pmocPlannedOperatorFor   PmocExecutionRequest[] @relation("PmocPlannedOperator")
  pmocPlannedTechnicianFor PmocExecutionRequest[] @relation("PmocPlannedTechnician")
  pmocExecutionRequests    PmocExecutionRequest[] @relation("PmocExecutionRequestActor")
  pmocHistoryEvents        PmocHistory[]          @relation("PmocHistoryActor")
  documentsCollected       OperationDocument[]    @relation("DocumentCollectedBy")
  documentsReviewed        OperationDocument[]    @relation("DocumentReviewedBy")
  documentsFinalized       OperationDocument[]    @relation("DocumentFinalizedBy")
  documentRevisions        DocumentRevision[]
  operationPhotosCreated   OperationPhoto[]       @relation("OperationPhotoCreatedBy")
  institutionalSignature   Signature?             @relation("UserInstitutionalSignature")
  salesCreated             Sale[]                 @relation("SaleCreatedBy")
  saleHistoryEvents        SaleHistory[]          @relation("SaleHistoryActor")

  @@map("users")
}

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Organization {
  id                  String                @id @default(uuid()) @db.Uuid
  legalName           String                @map("legal_name") @db.VarChar(180)
  tradeName           String                @map("trade_name") @db.VarChar(120)
  cnpj                String                @db.VarChar(18)
  stateRegistration   String?               @map("state_registration") @db.VarChar(30)
  email               String                @db.VarChar(254)
  phone               String                @db.VarChar(30)
  phoneNumbers        String[]              @default([]) @map("phone_numbers")
  website             String?               @db.VarChar(255)
  zipCode             String?               @map("zip_code") @db.VarChar(10)
  street              String?               @db.VarChar(180)
  number              String?               @db.VarChar(20)
  complement          String?               @db.VarChar(120)
  district            String?               @db.VarChar(120)
  city                String                @db.VarChar(100)
  state               String                @db.VarChar(2)
  primaryColor        String                @map("primary_color") @db.VarChar(7)
  secondaryColor      String                @map("secondary_color") @db.VarChar(7)
  segment             String?               @db.VarChar(80)
  isActive            Boolean               @default(true) @map("is_active")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  settings            OrganizationSettings?
  assets              BrandAsset[]
  templates           DocumentTemplate[]
  pmocPlans           PmocPlan[]
  inventoryItems      InventoryItem[]
  productPricings     ProductPricing[]
  budgets             Budget[]
  financialAccounts   FinancialAccount[]
  financialCategories FinancialCategory[]
  financialEntries    FinancialEntry[]
  purchaseOrders      PurchaseOrder[]
  notifications       Notification[]
  technicalCatalogs   TechnicalCatalog[]
  signatures          Signature[]
  sales               Sale[]

  @@map("organizations")
}

model OrganizationSettings {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  language       String       @db.VarChar(10)
  timezone       String       @db.VarChar(80)
  currency       String       @db.VarChar(3)
  documentPrefix String       @map("document_prefix") @db.VarChar(20)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model BrandAsset {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  type             BrandAssetType
  storageKey       String         @map("storage_key") @db.VarChar(255)
  mimeType         String         @map("mime_type") @db.VarChar(100)
  originalFileName String         @map("original_file_name") @db.VarChar(255)
  fileSize         Int            @map("file_size")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@map("brand_assets")
}

model DocumentTemplate {
  id                           String                      @id @default(uuid()) @db.Uuid
  organizationId               String                      @map("organization_id") @db.Uuid
  type                         DocumentTemplateType
  name                         String                      @db.VarChar(120)
  headerContent                String                      @map("header_content") @db.Text
  footerContent                String                      @map("footer_content") @db.Text
  observations                 String                      @db.Text
  isDefault                    Boolean                     @default(false) @map("is_default")
  isSystem                     Boolean                     @default(false) @map("is_system")
  isActive                     Boolean                     @default(true) @map("is_active")
  requiresSignature            Boolean                     @default(false) @map("requires_signature")
  signatureMode                SignatureMode               @default(NONE) @map("signature_mode")
  signatureId                  String?                     @map("signature_id") @db.Uuid
  executionSignatureClient     Boolean                     @default(false) @map("execution_signature_client")
  executionSignatureTechnician Boolean                     @default(false) @map("execution_signature_technician")
  executionSignatureOperator   Boolean                     @default(false) @map("execution_signature_operator")
  createdAt                    DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                    DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization                 Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signature                    Signature?                  @relation(fields: [signatureId], references: [id], onDelete: SetNull)
  institutionalSignatures      DocumentTemplateSignature[]

  @@index([organizationId, type])
  @@index([organizationId, isDefault])
  @@index([organizationId, isActive])
  @@index([signatureId])
  @@map("document_templates")
}

model Signature {
  id                  String                      @id @default(uuid()) @db.Uuid
  organizationId      String                      @map("organization_id") @db.Uuid
  userId              String?                     @unique @map("user_id") @db.Uuid
  name                String                      @db.VarChar(120)
  title               String                      @db.VarChar(120)
  profession          String?                     @db.VarChar(120)
  professionalCouncil String?                     @map("professional_council") @db.VarChar(120)
  registrationNumber  String?                     @map("registration_number") @db.VarChar(80)
  department          String?                     @db.VarChar(120)
  imageStorageKey     String?                     @unique @map("image_storage_key") @db.VarChar(255)
  mimeType            String?                     @map("mime_type") @db.VarChar(100)
  originalFileName    String?                     @map("original_file_name") @db.VarChar(255)
  fileSize            Int?                        @map("file_size")
  active              Boolean                     @default(true)
  isDefault           Boolean                     @default(false) @map("is_default")
  position            Int                         @default(0)
  deletedAt           DateTime?                   @map("deleted_at") @db.Timestamptz(3)
  createdAt           DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)
  templates           DocumentTemplate[]
  templateLinks       DocumentTemplateSignature[]
  pmocOverrides       PmocPlan[]
  organization        Organization                @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user                User?                       @relation("UserInstitutionalSignature", fields: [userId], references: [id], onDelete: SetNull)
  selectedDocuments   OperationDocument[]         @relation("DocumentTechnicalSignature")

  @@index([organizationId, active, position])
  @@index([userId])
  @@index([active, name])
  @@index([deletedAt])
  @@map("signatures")
}

model DocumentTemplateSignature {
  id          String           @id @default(uuid()) @db.Uuid
  templateId  String           @map("template_id") @db.Uuid
  signatureId String           @map("signature_id") @db.Uuid
  position    Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  template    DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  signature   Signature        @relation(fields: [signatureId], references: [id], onDelete: Restrict)

  @@unique([templateId, signatureId])
  @@index([templateId, position])
  @@index([signatureId])
  @@map("document_template_signatures")
}

model UserPreferences {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  theme                String   @default("SYSTEM") @db.VarChar(20)
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserPermission {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  canFinancial Boolean  @default(false) @map("can_financial")
  canUsers     Boolean  @default(false) @map("can_users")
  canReports   Boolean  @default(false) @map("can_reports")
  canSchedules Boolean  @default(false) @map("can_schedules")
  canTemplates Boolean  @default(false) @map("can_templates")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_permissions")
}

model UserAvatarAsset {
  id               String   @id @default(uuid()) @db.Uuid
  storageKey       String   @unique @map("storage_key") @db.VarChar(255)
  mimeType         String   @map("mime_type") @db.VarChar(100)
  originalFileName String   @map("original_file_name") @db.VarChar(255)
  fileSize         Int      @map("file_size")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user             User?

  @@map("user_avatar_assets")
}

model Notification {
  id              String                 @id @default(uuid()) @db.Uuid
  organizationId  String                 @map("organization_id") @db.Uuid
  recipientUserId String                 @map("recipient_user_id") @db.Uuid
  type            NotificationType
  severity        NotificationSeverity   @default(INFO)
  title           String                 @db.VarChar(140)
  message         String                 @db.VarChar(300)
  entityType      NotificationEntityType @map("entity_type")
  entityId        String                 @map("entity_id") @db.Uuid
  actionUrl       String?                @map("action_url") @db.VarChar(255)
  eventKey        String                 @map("event_key") @db.VarChar(180)
  readAt          DateTime?              @map("read_at") @db.Timestamptz(3)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt       DateTime?              @map("deleted_at") @db.Timestamptz(3)
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipient       User                   @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([recipientUserId, eventKey])
  @@index([organizationId, createdAt])
  @@index([recipientUserId, readAt, createdAt])
  @@index([type, createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

model Customer {
  id             String               @id @default(uuid()) @db.Uuid
  type           CustomerType
  name           String               @db.VarChar(180)
  tradeName      String?              @map("trade_name") @db.VarChar(180)
  cpf            String?              @unique @db.VarChar(14)
  cnpj           String?              @unique @db.VarChar(18)
  email          String?              @db.VarChar(254)
  phone          String?              @db.VarChar(30)
  secondaryPhone String?              @map("secondary_phone") @db.VarChar(30)
  notes          String?              @db.Text
  isActive       Boolean              @default(true) @map("is_active")
  disabledAt     DateTime?            @map("disabled_at") @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  addresses      CustomerAddress[]
  contacts       CustomerContact[]
  attachments    CustomerAttachment[]
  equipments     Equipment[]
  operations     Operation[]
  pmocPlans      PmocPlan[]
  budgets        Budget[]
  sales          Sale[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([isActive, type])
  @@map("customers")
}

model CustomerAddress {
  id                      String      @id @default(uuid()) @db.Uuid
  customerId              String      @map("customer_id") @db.Uuid
  name                    String      @db.VarChar(100)
  zipCode                 String      @map("zip_code") @db.VarChar(9)
  street                  String      @db.VarChar(180)
  number                  String      @db.VarChar(20)
  complement              String?     @db.VarChar(120)
  district                String      @db.VarChar(100)
  city                    String      @db.VarChar(100)
  state                   String      @db.VarChar(2)
  isPrimary               Boolean     @default(false) @map("is_primary")
  createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer                Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipments              Equipment[]
  operations              Operation[]
  budgets                 Budget[]
  sales                   Sale[]
  pmocDefaultAddressPlans PmocPlan[]

