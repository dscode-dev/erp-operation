generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
  VIEWER
}

enum BrandAssetType {
  LOGO
  HEADER
  FOOTER
}

enum DocumentTemplateType {
  BUDGET
  QUOTE
  WORK_ORDER
  RECEIPT
  REPORT
  TECHNICAL_REPORT
  TECHNICAL_OPINION
  PMOC
}

enum CustomerType {
  PERSON
  COMPANY
}

enum EquipmentType {
  SPLIT
  CHILLER
  CONDENSER
  EVAPORATOR
  AIR_HANDLER
  SOLAR_INVERTER
  ELECTRICAL_PANEL
  GENERATOR
  OTHER
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
  RETIRED
}

enum EquipmentAttachmentCategory {
  PHOTO
  MANUAL
  WARRANTY
  DOCUMENT
