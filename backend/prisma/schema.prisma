/// A document produced from an Operation. The same record backs every document
/// type via DocumentTemplateType; the Work Order is generated automatically as a
/// DRAFT when an Operation is created. PDF generation is future scope.
model OperationDocument {
  id                         String                  @id @default(uuid()) @db.Uuid
  operationId                String?                 @map("operation_id") @db.Uuid
  budgetId                   String?                 @unique @map("budget_id") @db.Uuid
  type                       DocumentTemplateType
  number                     String                  @db.VarChar(40)
  status                     OperationDocumentStatus @default(DRAFT)
  editorialStatus            DocumentEditorialStatus @default(DRAFT) @map("editorial_status")
  handoffOrigin              DocumentHandoffOrigin   @default(SYSTEM) @map("handoff_origin")
  collectedById              String?                 @map("collected_by_id") @db.Uuid
  submittedAt                DateTime?               @map("submitted_at") @db.Timestamptz(3)
  reviewedById               String?                 @map("reviewed_by_id") @db.Uuid
  reviewStartedAt            DateTime?               @map("review_started_at") @db.Timestamptz(3)
  finalizedById              String?                 @map("finalized_by_id") @db.Uuid
  finalizedAt                DateTime?               @map("finalized_at") @db.Timestamptz(3)
  technicalSignatureId       String?                 @map("technical_signature_id") @db.Uuid
  technicalSignatureSnapshot Json?                   @map("technical_signature_snapshot")
  customerSignatureSnapshot  Json?                   @map("customer_signature_snapshot")
  collectionSnapshot         Json?                   @map("collection_snapshot")
  validationIssues           Json                    @default("[]") @map("validation_issues")
  revision                   Int                     @default(0)
  storageKey                 String?                 @unique @map("storage_key") @db.VarChar(255)
  mimeType                   String?                 @map("mime_type") @db.VarChar(100)
  fileSize                   Int?                    @map("file_size")
  renderedAt                 DateTime?               @map("rendered_at") @db.Timestamptz(3)
  renderMetadata             Json?                   @map("render_metadata")
  createdAt                  DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)
  operation                  Operation?              @relation(fields: [operationId], references: [id], onDelete: Cascade)
  budget                     Budget?                 @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  lifecycleEvents            AssetLifecycleEvent[]
  collectedBy                User?                   @relation("DocumentCollectedBy", fields: [collectedById], references: [id], onDelete: SetNull)
  reviewedBy                 User?                   @relation("DocumentReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  finalizedBy                User?                   @relation("DocumentFinalizedBy", fields: [finalizedById], references: [id], onDelete: SetNull)
  technicalSignature         Signature?              @relation("DocumentTechnicalSignature", fields: [technicalSignatureId], references: [id], onDelete: SetNull)
  revisions                  DocumentRevision[]

  @@unique([operationId, type])
  @@index([budgetId])
  @@index([type, status])
  @@index([renderedAt])
  @@index([editorialStatus, submittedAt])
  @@index([handoffOrigin, editorialStatus, updatedAt])
  @@index([technicalSignatureId])
  @@map("operation_documents")
}

