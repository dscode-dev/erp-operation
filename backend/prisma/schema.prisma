generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
  VIEWER
}

enum BrandAssetType {
  LOGO
  HEADER
  FOOTER
}

enum DocumentTemplateType {
  BUDGET
  QUOTE
  WORK_ORDER
  RECEIPT
  REPORT
  TECHNICAL_REPORT
  TECHNICAL_OPINION
  PMOC
}

enum CustomerType {
  PERSON
  COMPANY
}

enum EquipmentType {
  SPLIT
  CHILLER
  CONDENSER
  EVAPORATOR
  AIR_HANDLER
  SOLAR_INVERTER
  ELECTRICAL_PANEL
  GENERATOR
  OTHER
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
  RETIRED
}

enum EquipmentAttachmentCategory {
  PHOTO
  MANUAL
  WARRANTY
  DOCUMENT
}

enum OperationType {
  PREVENTIVA
  CORRETIVA
  INSTALACAO
  PROJETO
}

enum OperationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum OperationDocumentStatus {
  DRAFT
  READY
  VALIDATED
  SENT
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  STARTED
  PAUSED
  COMPLETED
  CANCELED
  REJECTED
}

enum AssignmentEventType {
  ASSIGNED
  REASSIGNED
  ACCEPTED
  STARTED
  PAUSED
  RESUMED
  REJECTED
  COMPLETED
  CANCELED
}

enum BudgetStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELED
}

enum BudgetHistoryAction {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
  CANCELED
  ITEM_ADDED
  ITEM_UPDATED
  ITEM_REMOVED
  DOCUMENT_RENDERED
}

enum SignatureMode {
  NONE
  FIXED
  COLLECTED
  HYBRID
}

enum AssetLifecycleEventType {
  INSTALLATION
  INSPECTION
  PREVENTIVE
  CORRECTIVE
  MAINTENANCE
  ASSIGNMENT_CREATED
  ASSIGNMENT_REASSIGNED
  ASSIGNMENT_ACCEPTED
  ASSIGNMENT_STARTED
  ASSIGNMENT_COMPLETED
  BUDGET_APPROVED
  BUDGET_REJECTED
  PMOC_CREATED
  PMOC_UPDATED
  PMOC_COMPLETED
  PMOC_EXPIRED
  PART_REPLACEMENT
  WARRANTY
  DOCUMENT
  DOCUMENT_RENDERED
  FINANCIAL_ENTRY_CREATED
  FINANCIAL_ENTRY_PAID
  FINANCIAL_ENTRY_CANCELED
  PURCHASE_CREATED
  PURCHASE_RECEIVED
  PURCHASE_CANCELED
  NOTE
  CUSTOM
}

enum MaintenancePlanType {
  PREVENTIVE
  INSPECTION
  WARRANTY
  CUSTOM
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceExecutionStatus {
  PLANNED
  LINKED
  COMPLETED
  CANCELED
}

enum PmocComplianceStatus {
  COMPLIANT
  WARNING
  OVERDUE
  NON_COMPLIANT
  IN_PROGRESS
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  CONSUMPTION
  RETURN
}

enum FinancialAccountType {
  CASH
  BANK
  CREDIT_CARD
  DIGITAL_WALLET
  OTHER
}

enum FinancialCategoryType {
  INCOME
  EXPENSE
  TRANSFER
}

enum FinancialEntryType {
  RECEIVABLE
  PAYABLE
  TRANSFER
}

enum FinancialEntryStatus {
  PENDING
  PAID
  CANCELED
  OVERDUE
}

enum FinancialEntryOrigin {
  MANUAL
  BUDGET
  PURCHASE
  OPERATION
  PMOC
  OTHER
}

enum FinancialHistoryAction {
  CREATED
  UPDATED
  PAID
  CANCELED
  RESTORED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELED
}

enum PurchaseHistoryAction {
  CREATED
  UPDATED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELED
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(150)
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("system_settings")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String   @db.VarChar(100)
  resource  String   @db.VarChar(150)
  actor     String?  @db.VarChar(255)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([resource, createdAt])
  @@index([actor, createdAt])
  @@map("audit_logs")
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  email                String                @unique @db.VarChar(254)
  username             String                @unique @db.VarChar(50)
  name                 String                @db.VarChar(150)
  passwordHash         String                @map("password_hash") @db.VarChar(255)
  role                 Role
  avatarAssetId        String?               @unique @map("avatar_asset_id") @db.Uuid
  phone                String?               @db.VarChar(30)
  jobTitle             String?               @map("job_title") @db.VarChar(100)
  notes                String?               @db.Text
  mustChangePassword   Boolean               @default(false) @map("must_change_password")
  isActive             Boolean               @default(true) @map("is_active")
  disabledAt           DateTime?             @map("disabled_at") @db.Timestamptz(3)
  lastLoginAt          DateTime?             @map("last_login_at") @db.Timestamptz(3)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  refreshTokens        RefreshToken[]
  preferences          UserPreferences?
  permission           UserPermission?
  avatarAsset          UserAvatarAsset?      @relation(fields: [avatarAssetId], references: [id], onDelete: SetNull)
  operations           Operation[]
  assignmentsCreated   Assignment[]          @relation("AssignmentAssignedBy")
  assignmentsReceived  Assignment[]          @relation("AssignmentAssignedTo")
  assignmentEvents     AssignmentHistory[]   @relation("AssignmentHistoryActor")
  assetLifecycleEvents AssetLifecycleEvent[]
  maintenancePlans     MaintenancePlan[]
  stockMovements       StockMovement[]
  budgetsCreated       Budget[]              @relation("BudgetCreatedBy")
  budgetApprovals      BudgetApproval[]      @relation("BudgetApprovalActor")
  budgetHistoryEvents  BudgetHistory[]       @relation("BudgetHistoryActor")
  financialEntriesCreated FinancialEntry[]   @relation("FinancialEntryCreatedBy")
  financialHistoryEvents   FinancialHistory[] @relation("FinancialHistoryActor")
  purchaseOrdersCreated    PurchaseOrder[]    @relation("PurchaseOrderCreatedBy")
  purchaseReceiptsReceived PurchaseReceipt[]  @relation("PurchaseReceiptReceivedBy")
  purchaseHistoryEvents    PurchaseHistory[]  @relation("PurchaseHistoryActor")

  @@map("users")
}

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Organization {
  id             String                @id @default(uuid()) @db.Uuid
  legalName      String                @map("legal_name") @db.VarChar(180)
  tradeName      String                @map("trade_name") @db.VarChar(120)
  cnpj           String                @db.VarChar(18)
  email          String                @db.VarChar(254)
  phone          String                @db.VarChar(30)
  city           String                @db.VarChar(100)
  state          String                @db.VarChar(2)
  primaryColor   String                @map("primary_color") @db.VarChar(7)
  secondaryColor String                @map("secondary_color") @db.VarChar(7)
  segment        String?               @db.VarChar(80)
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  settings       OrganizationSettings?
  assets         BrandAsset[]
  templates      DocumentTemplate[]
  pmocPlans      PmocPlan[]
  inventoryItems InventoryItem[]
  productPricings ProductPricing[]
  budgets         Budget[]
  financialAccounts   FinancialAccount[]
  financialCategories FinancialCategory[]
  financialEntries    FinancialEntry[]
  purchaseOrders      PurchaseOrder[]

  @@map("organizations")
}

model OrganizationSettings {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  language       String       @db.VarChar(10)
  timezone       String       @db.VarChar(80)
  currency       String       @db.VarChar(3)
  documentPrefix String       @map("document_prefix") @db.VarChar(20)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model BrandAsset {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  type             BrandAssetType
  storageKey       String         @map("storage_key") @db.VarChar(255)
  mimeType         String         @map("mime_type") @db.VarChar(100)
  originalFileName String         @map("original_file_name") @db.VarChar(255)
  fileSize         Int            @map("file_size")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@map("brand_assets")
}

model DocumentTemplate {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @map("organization_id") @db.Uuid
  type              DocumentTemplateType
  name              String               @db.VarChar(120)
  headerContent     String               @map("header_content") @db.Text
  footerContent     String               @map("footer_content") @db.Text
  observations      String               @db.Text
  isDefault         Boolean              @default(false) @map("is_default")
  isSystem          Boolean              @default(false) @map("is_system")
  isActive          Boolean              @default(true) @map("is_active")
  requiresSignature Boolean              @default(false) @map("requires_signature")
  signatureMode     SignatureMode        @default(NONE) @map("signature_mode")
  signatureId       String?              @map("signature_id") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signature         Signature?           @relation(fields: [signatureId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
  @@index([organizationId, isDefault])
  @@index([organizationId, isActive])
  @@index([signatureId])
  @@map("document_templates")
}

model Signature {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @db.VarChar(120)
  title            String             @db.VarChar(120)
  imageStorageKey  String?            @unique @map("image_storage_key") @db.VarChar(255)
  mimeType         String?            @map("mime_type") @db.VarChar(100)
  originalFileName String?            @map("original_file_name") @db.VarChar(255)
  fileSize         Int?               @map("file_size")
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  templates        DocumentTemplate[]

  @@index([active, name])
  @@map("signatures")
}

model UserPreferences {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  theme                String   @default("SYSTEM") @db.VarChar(20)
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserPermission {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  canFinancial Boolean  @default(false) @map("can_financial")
  canUsers     Boolean  @default(false) @map("can_users")
  canReports   Boolean  @default(false) @map("can_reports")
  canSchedules Boolean  @default(false) @map("can_schedules")
  canTemplates Boolean  @default(false) @map("can_templates")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_permissions")
}

model UserAvatarAsset {
  id               String   @id @default(uuid()) @db.Uuid
  storageKey       String   @unique @map("storage_key") @db.VarChar(255)
  mimeType         String   @map("mime_type") @db.VarChar(100)
  originalFileName String   @map("original_file_name") @db.VarChar(255)
  fileSize         Int      @map("file_size")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user             User?

  @@map("user_avatar_assets")
}

model Customer {
  id             String               @id @default(uuid()) @db.Uuid
  type           CustomerType
  name           String               @db.VarChar(180)
  tradeName      String?              @map("trade_name") @db.VarChar(180)
  cpf            String?              @unique @db.VarChar(14)
  cnpj           String?              @unique @db.VarChar(18)
  email          String?              @db.VarChar(254)
  phone          String?              @db.VarChar(30)
  secondaryPhone String?              @map("secondary_phone") @db.VarChar(30)
  notes          String?              @db.Text
  isActive       Boolean              @default(true) @map("is_active")
  disabledAt     DateTime?            @map("disabled_at") @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  addresses      CustomerAddress[]
  contacts       CustomerContact[]
  attachments    CustomerAttachment[]
  equipments     Equipment[]
  operations     Operation[]
  pmocPlans      PmocPlan[]
  budgets        Budget[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([isActive, type])
  @@map("customers")
}

model CustomerAddress {
  id         String      @id @default(uuid()) @db.Uuid
  customerId String      @map("customer_id") @db.Uuid
  name       String      @db.VarChar(100)
  zipCode    String      @map("zip_code") @db.VarChar(9)
  street     String      @db.VarChar(180)
  number     String      @db.VarChar(20)
  complement String?     @db.VarChar(120)
  district   String      @db.VarChar(100)
  city       String      @db.VarChar(100)
  state      String      @db.VarChar(2)
  isPrimary  Boolean     @default(false) @map("is_primary")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipments Equipment[]
  operations Operation[]
  budgets    Budget[]

  @@index([customerId, isPrimary])
  @@map("customer_addresses")
}

model CustomerContact {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  name       String   @db.VarChar(150)
  role       String?  @db.VarChar(100)
  phone      String?  @db.VarChar(30)
  email      String?  @db.VarChar(254)
  notes      String?  @db.Text
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isPrimary])
  @@map("customer_contacts")
}

model CustomerAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  storageKey String   @unique @map("storage_key") @db.VarChar(255)
  fileName   String   @map("file_name") @db.VarChar(255)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  fileSize   Int      @map("file_size")
  category   String   @db.VarChar(80)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("customer_attachments")
}

model Equipment {
  id                 String                     @id @default(uuid()) @db.Uuid
  customerId         String                     @map("customer_id") @db.Uuid
  addressId          String?                    @map("address_id") @db.Uuid
  parentEquipmentId  String?                    @map("parent_equipment_id") @db.Uuid
  type               EquipmentType
  status             EquipmentStatus            @default(ACTIVE)
  name               String                     @db.VarChar(180)
  tag                String?                    @db.VarChar(80)
  manufacturer       String?                    @db.VarChar(120)
  model              String?                    @db.VarChar(120)
  serialNumber       String?                    @map("serial_number") @db.VarChar(120)
  capacity           String?                    @db.VarChar(80)
  voltage            String?                    @db.VarChar(40)
  installationDate   DateTime?                  @map("installation_date") @db.Date
  warrantyExpiration DateTime?                  @map("warranty_expiration") @db.Date
  observations       String?                    @db.Text
  qrToken            String                     @unique @default(uuid()) @map("qr_token") @db.Uuid
  qrCode             String                     @unique @map("qr_code") @db.VarChar(100)
  isActive           Boolean                    @default(true) @map("is_active")
  disabledAt         DateTime?                  @map("disabled_at") @db.Timestamptz(3)
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer           Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address            CustomerAddress?           @relation(fields: [addressId], references: [id], onDelete: SetNull)
  parent             Equipment?                 @relation("EquipmentHierarchy", fields: [parentEquipmentId], references: [id], onDelete: SetNull)
  children           Equipment[]                @relation("EquipmentHierarchy")
  attachments        EquipmentAttachment[]
  metrics            EquipmentMetric[]
  operations         Operation[]
  lifecycleEvents    AssetLifecycleEvent[]
  maintenancePlans   MaintenancePlan[]
  pmocPrimaryPlans   PmocPlan[]
  pmocLinks          PmocPlanEquipment[]
  pmocEnvironments   PmocEnvironmentEquipment[]
  budgets            Budget[]

  @@index([customerId, status])
  @@index([addressId])
  @@index([parentEquipmentId])
  @@index([type, isActive])
  @@index([name])
  @@index([tag])
  @@index([serialNumber])
  @@map("equipments")
}

model EquipmentAttachment {
  id          String                      @id @default(uuid()) @db.Uuid
  equipmentId String                      @map("equipment_id") @db.Uuid
  storageKey  String                      @unique @map("storage_key") @db.VarChar(255)
  fileName    String                      @map("file_name") @db.VarChar(255)
  mimeType    String                      @map("mime_type") @db.VarChar(100)
  fileSize    Int                         @map("file_size")
  category    EquipmentAttachmentCategory
  createdAt   DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  equipment   Equipment                   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, createdAt])
  @@map("equipment_attachments")
}

model EquipmentMetric {
  id          String    @id @default(uuid()) @db.Uuid
  equipmentId String    @map("equipment_id") @db.Uuid
  key         String    @db.VarChar(80)
  value       Float
  unit        String    @db.VarChar(30)
  recordedAt  DateTime  @map("recorded_at") @db.Timestamptz(3)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, recordedAt])
  @@index([equipmentId, key])
  @@map("equipment_metrics")
}

/// Central operational domain. A field service (atendimento) is the foundation
/// reused by every produced document (OS, PMOC, Laudo, Relatório, Orçamento,
/// Recibo). Each Work Order goes through exactly one Operation.
model Operation {
  id                   String                @id @default(uuid()) @db.Uuid
  number               Int                   @unique @default(autoincrement())
  customerId           String                @map("customer_id") @db.Uuid
  addressId            String?               @map("address_id") @db.Uuid
  equipmentId          String?               @map("equipment_id") @db.Uuid
  operatorId           String                @map("operator_id") @db.Uuid
  type                 OperationType
  status               OperationStatus       @default(DRAFT)
  scheduledFor         DateTime?             @map("scheduled_for") @db.Timestamptz(3)
  startedAt            DateTime?             @map("started_at") @db.Timestamptz(3)
  completedAt          DateTime?             @map("completed_at") @db.Timestamptz(3)
  checklist            Json                  @default("[]")
  observations         String?               @db.Text
  signatureData        String?               @map("signature_data") @db.Text
  signedAt             DateTime?             @map("signed_at") @db.Timestamptz(3)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer             Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address              CustomerAddress?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  equipment            Equipment?            @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  operator             User                  @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  photos               OperationPhoto[]
  documents            OperationDocument[]
  assignment           Assignment?
  assignmentHistory    AssignmentHistory[]
  lifecycleEvents      AssetLifecycleEvent[]
  maintenanceExecution MaintenanceExecution?
  parts                OperationPart[]
  stockMovements       StockMovement[]
  budgets              Budget[]

  @@index([customerId, createdAt])
  @@index([equipmentId, createdAt])
  @@index([operatorId, createdAt])
  @@index([status, createdAt])
  @@map("operations")
}

model Assignment {
  id              String              @id @default(uuid()) @db.Uuid
  operationId     String              @unique @map("operation_id") @db.Uuid
  assignedBy      String              @map("assigned_by") @db.Uuid
  assignedTo      String              @map("assigned_to") @db.Uuid
  status          AssignmentStatus    @default(ASSIGNED)
  assignedAt      DateTime            @default(now()) @map("assigned_at") @db.Timestamptz(3)
  acceptedAt      DateTime?           @map("accepted_at") @db.Timestamptz(3)
  startedAt       DateTime?           @map("started_at") @db.Timestamptz(3)
  completedAt     DateTime?           @map("completed_at") @db.Timestamptz(3)
  canceledAt      DateTime?           @map("canceled_at") @db.Timestamptz(3)
  rejectedAt      DateTime?           @map("rejected_at") @db.Timestamptz(3)
  rejectionReason String?             @map("rejection_reason") @db.Text
  notes           String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  operation       Operation           @relation(fields: [operationId], references: [id], onDelete: Cascade)
