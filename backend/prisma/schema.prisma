generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
  VIEWER
}

enum BrandAssetType {
  LOGO
  HEADER
  FOOTER
}

enum DocumentTemplateType {
  QUOTE
  WORK_ORDER
  RECEIPT
  REPORT
  TECHNICAL_REPORT
  PMOC
}

enum CustomerType {
  PERSON
  COMPANY
}

enum EquipmentType {
  SPLIT
  CHILLER
  CONDENSER
  EVAPORATOR
  AIR_HANDLER
  SOLAR_INVERTER
  ELECTRICAL_PANEL
  GENERATOR
  OTHER
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
  RETIRED
}

enum EquipmentAttachmentCategory {
  PHOTO
  MANUAL
  WARRANTY
  DOCUMENT
}

enum OperationType {
  PREVENTIVA
  CORRETIVA
  INSTALACAO
  PROJETO
}

enum OperationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum OperationDocumentStatus {
  DRAFT
  READY
  VALIDATED
  SENT
}

enum SignatureMode {
  NONE
  FIXED
  COLLECTED
  HYBRID
}

enum AssetLifecycleEventType {
  INSTALLATION
  INSPECTION
  PREVENTIVE
  CORRECTIVE
  MAINTENANCE
  PMOC_CREATED
  PMOC_UPDATED
  PMOC_COMPLETED
  PMOC_EXPIRED
  PART_REPLACEMENT
  WARRANTY
  DOCUMENT
  NOTE
  CUSTOM
}

enum MaintenancePlanType {
  PREVENTIVE
  INSPECTION
  WARRANTY
  CUSTOM
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceExecutionStatus {
  PLANNED
  LINKED
  COMPLETED
  CANCELED
}

enum PmocComplianceStatus {
  COMPLIANT
  WARNING
  OVERDUE
  NON_COMPLIANT
  IN_PROGRESS
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  CONSUMPTION
  RETURN
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(150)
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("system_settings")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String   @db.VarChar(100)
  resource  String   @db.VarChar(150)
  actor     String?  @db.VarChar(255)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([resource, createdAt])
  @@index([actor, createdAt])
  @@map("audit_logs")
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  email                String                @unique @db.VarChar(254)
  username             String                @unique @db.VarChar(50)
  name                 String                @db.VarChar(150)
  passwordHash         String                @map("password_hash") @db.VarChar(255)
  role                 Role
  avatarAssetId        String?               @unique @map("avatar_asset_id") @db.Uuid
  phone                String?               @db.VarChar(30)
  jobTitle             String?               @map("job_title") @db.VarChar(100)
  notes                String?               @db.Text
  mustChangePassword   Boolean               @default(false) @map("must_change_password")
  isActive             Boolean               @default(true) @map("is_active")
  disabledAt           DateTime?             @map("disabled_at") @db.Timestamptz(3)
  lastLoginAt          DateTime?             @map("last_login_at") @db.Timestamptz(3)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  refreshTokens        RefreshToken[]
  preferences          UserPreferences?
  permission           UserPermission?
  avatarAsset          UserAvatarAsset?      @relation(fields: [avatarAssetId], references: [id], onDelete: SetNull)
  operations           Operation[]
  assetLifecycleEvents AssetLifecycleEvent[]
  maintenancePlans     MaintenancePlan[]
  stockMovements       StockMovement[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Organization {
  id             String                @id @default(uuid()) @db.Uuid
  legalName      String                @map("legal_name") @db.VarChar(180)
  tradeName      String                @map("trade_name") @db.VarChar(120)
  cnpj           String                @db.VarChar(18)
  email          String                @db.VarChar(254)
  phone          String                @db.VarChar(30)
  city           String                @db.VarChar(100)
  state          String                @db.VarChar(2)
  primaryColor   String                @map("primary_color") @db.VarChar(7)
  secondaryColor String                @map("secondary_color") @db.VarChar(7)
  segment        String?               @db.VarChar(80)
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  settings       OrganizationSettings?
  assets         BrandAsset[]
  templates      DocumentTemplate[]
  pmocPlans      PmocPlan[]
  inventoryItems InventoryItem[]

  @@map("organizations")
}

model OrganizationSettings {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  language       String       @db.VarChar(10)
  timezone       String       @db.VarChar(80)
  currency       String       @db.VarChar(3)
  documentPrefix String       @map("document_prefix") @db.VarChar(20)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model BrandAsset {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  type             BrandAssetType
  storageKey       String         @map("storage_key") @db.VarChar(255)
  mimeType         String         @map("mime_type") @db.VarChar(100)
  originalFileName String         @map("original_file_name") @db.VarChar(255)
  fileSize         Int            @map("file_size")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@map("brand_assets")
}

model DocumentTemplate {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @map("organization_id") @db.Uuid
  type              DocumentTemplateType
  name              String               @db.VarChar(120)
  headerContent     String               @map("header_content") @db.Text
  footerContent     String               @map("footer_content") @db.Text
  observations      String               @db.Text
  isDefault         Boolean              @default(false) @map("is_default")
  isSystem          Boolean              @default(false) @map("is_system")
  isActive          Boolean              @default(true) @map("is_active")
  requiresSignature Boolean              @default(false) @map("requires_signature")
  signatureMode     SignatureMode        @default(NONE) @map("signature_mode")
  signatureId       String?              @map("signature_id") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signature         Signature?           @relation(fields: [signatureId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
  @@index([organizationId, isDefault])
  @@index([organizationId, isActive])
  @@index([signatureId])
  @@map("document_templates")
}

model Signature {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @db.VarChar(120)
  title            String             @db.VarChar(120)
  imageStorageKey  String?            @unique @map("image_storage_key") @db.VarChar(255)
  mimeType         String?            @map("mime_type") @db.VarChar(100)
  originalFileName String?            @map("original_file_name") @db.VarChar(255)
  fileSize         Int?               @map("file_size")
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  templates        DocumentTemplate[]

  @@index([active, name])
  @@map("signatures")
}

model UserPreferences {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  theme                String   @default("SYSTEM") @db.VarChar(20)
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserPermission {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  canFinancial Boolean  @default(false) @map("can_financial")
  canUsers     Boolean  @default(false) @map("can_users")
  canReports   Boolean  @default(false) @map("can_reports")
  canSchedules Boolean  @default(false) @map("can_schedules")
  canTemplates Boolean  @default(false) @map("can_templates")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_permissions")
}

model UserAvatarAsset {
  id               String   @id @default(uuid()) @db.Uuid
  storageKey       String   @unique @map("storage_key") @db.VarChar(255)
  mimeType         String   @map("mime_type") @db.VarChar(100)
  originalFileName String   @map("original_file_name") @db.VarChar(255)
  fileSize         Int      @map("file_size")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user             User?

  @@map("user_avatar_assets")
}

model Customer {
  id             String               @id @default(uuid()) @db.Uuid
  type           CustomerType
  name           String               @db.VarChar(180)
  tradeName      String?              @map("trade_name") @db.VarChar(180)
  cpf            String?              @unique @db.VarChar(14)
  cnpj           String?              @unique @db.VarChar(18)
  email          String?              @db.VarChar(254)
  phone          String?              @db.VarChar(30)
  secondaryPhone String?              @map("secondary_phone") @db.VarChar(30)
  notes          String?              @db.Text
  isActive       Boolean              @default(true) @map("is_active")
  disabledAt     DateTime?            @map("disabled_at") @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  addresses      CustomerAddress[]
  contacts       CustomerContact[]
  attachments    CustomerAttachment[]
  equipments     Equipment[]
  operations     Operation[]
  pmocPlans      PmocPlan[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([isActive, type])
  @@map("customers")
}

model CustomerAddress {
  id         String      @id @default(uuid()) @db.Uuid
  customerId String      @map("customer_id") @db.Uuid
  name       String      @db.VarChar(100)
  zipCode    String      @map("zip_code") @db.VarChar(9)
  street     String      @db.VarChar(180)
  number     String      @db.VarChar(20)
  complement String?     @db.VarChar(120)
  district   String      @db.VarChar(100)
  city       String      @db.VarChar(100)
  state      String      @db.VarChar(2)
  isPrimary  Boolean     @default(false) @map("is_primary")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipments Equipment[]
  operations Operation[]

  @@index([customerId, isPrimary])
  @@map("customer_addresses")
}

model CustomerContact {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  name       String   @db.VarChar(150)
  role       String?  @db.VarChar(100)
  phone      String?  @db.VarChar(30)
  email      String?  @db.VarChar(254)
  notes      String?  @db.Text
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isPrimary])
  @@map("customer_contacts")
}

model CustomerAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  storageKey String   @unique @map("storage_key") @db.VarChar(255)
  fileName   String   @map("file_name") @db.VarChar(255)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  fileSize   Int      @map("file_size")
  category   String   @db.VarChar(80)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("customer_attachments")
}

model Equipment {
  id                 String                     @id @default(uuid()) @db.Uuid
  customerId         String                     @map("customer_id") @db.Uuid
  addressId          String?                    @map("address_id") @db.Uuid
  parentEquipmentId  String?                    @map("parent_equipment_id") @db.Uuid
  type               EquipmentType
  status             EquipmentStatus            @default(ACTIVE)
  name               String                     @db.VarChar(180)
  tag                String?                    @db.VarChar(80)
  manufacturer       String?                    @db.VarChar(120)
  model              String?                    @db.VarChar(120)
  serialNumber       String?                    @map("serial_number") @db.VarChar(120)
  capacity           String?                    @db.VarChar(80)
  voltage            String?                    @db.VarChar(40)
  installationDate   DateTime?                  @map("installation_date") @db.Date
  warrantyExpiration DateTime?                  @map("warranty_expiration") @db.Date
  observations       String?                    @db.Text
  qrToken            String                     @unique @default(uuid()) @map("qr_token") @db.Uuid
  qrCode             String                     @unique @map("qr_code") @db.VarChar(100)
  isActive           Boolean                    @default(true) @map("is_active")
  disabledAt         DateTime?                  @map("disabled_at") @db.Timestamptz(3)
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer           Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address            CustomerAddress?           @relation(fields: [addressId], references: [id], onDelete: SetNull)
  parent             Equipment?                 @relation("EquipmentHierarchy", fields: [parentEquipmentId], references: [id], onDelete: SetNull)
  children           Equipment[]                @relation("EquipmentHierarchy")
  attachments        EquipmentAttachment[]
  metrics            EquipmentMetric[]
  operations         Operation[]
  lifecycleEvents    AssetLifecycleEvent[]
  maintenancePlans   MaintenancePlan[]
  pmocPrimaryPlans   PmocPlan[]
  pmocLinks          PmocPlanEquipment[]
  pmocEnvironments   PmocEnvironmentEquipment[]

  @@index([customerId, status])
  @@index([addressId])
  @@index([parentEquipmentId])
  @@index([type, isActive])
  @@index([name])
  @@index([tag])
  @@index([serialNumber])
  @@map("equipments")
}

model EquipmentAttachment {
  id          String                      @id @default(uuid()) @db.Uuid
  equipmentId String                      @map("equipment_id") @db.Uuid
  storageKey  String                      @unique @map("storage_key") @db.VarChar(255)
  fileName    String                      @map("file_name") @db.VarChar(255)
  mimeType    String                      @map("mime_type") @db.VarChar(100)
  fileSize    Int                         @map("file_size")
  category    EquipmentAttachmentCategory
  createdAt   DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  equipment   Equipment                   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, createdAt])
  @@map("equipment_attachments")
}

model EquipmentMetric {
  id          String    @id @default(uuid()) @db.Uuid
  equipmentId String    @map("equipment_id") @db.Uuid
  key         String    @db.VarChar(80)
  value       Float
  unit        String    @db.VarChar(30)
  recordedAt  DateTime  @map("recorded_at") @db.Timestamptz(3)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, recordedAt])
  @@index([equipmentId, key])
  @@map("equipment_metrics")
}

/// Central operational domain. A field service (atendimento) is the foundation
/// reused by every produced document (OS, PMOC, Laudo, Relatório, Orçamento,
/// Recibo). Each Work Order goes through exactly one Operation.
model Operation {
  id                   String                @id @default(uuid()) @db.Uuid
  number               Int                   @unique @default(autoincrement())
  customerId           String                @map("customer_id") @db.Uuid
  addressId            String?               @map("address_id") @db.Uuid
  equipmentId          String?               @map("equipment_id") @db.Uuid
  operatorId           String                @map("operator_id") @db.Uuid
  type                 OperationType
  status               OperationStatus       @default(DRAFT)
  scheduledFor         DateTime?             @map("scheduled_for") @db.Timestamptz(3)
  startedAt            DateTime?             @map("started_at") @db.Timestamptz(3)
  completedAt          DateTime?             @map("completed_at") @db.Timestamptz(3)
  checklist            Json                  @default("[]")
  observations         String?               @db.Text
  signatureData        String?               @map("signature_data") @db.Text
  signedAt             DateTime?             @map("signed_at") @db.Timestamptz(3)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  customer             Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address              CustomerAddress?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  equipment            Equipment?            @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  operator             User                  @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  photos               OperationPhoto[]
  documents            OperationDocument[]
  lifecycleEvents      AssetLifecycleEvent[]
  maintenanceExecution MaintenanceExecution?
  parts                OperationPart[]
  stockMovements       StockMovement[]

  @@index([customerId, createdAt])
  @@index([equipmentId, createdAt])
  @@index([operatorId, createdAt])
  @@index([status, createdAt])
  @@map("operations")
}

model OperationPhoto {
  id          String    @id @default(uuid()) @db.Uuid
  operationId String    @map("operation_id") @db.Uuid
  storageKey  String    @unique @map("storage_key") @db.VarChar(255)
  caption     String?   @db.VarChar(255)
  mimeType    String    @map("mime_type") @db.VarChar(100)
  fileSize    Int       @map("file_size")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([operationId, createdAt])
  @@map("operation_photos")
}

/// A document produced from an Operation. The same record backs every document
/// type via DocumentTemplateType; the Work Order is generated automatically as a
/// DRAFT when an Operation is created. PDF generation is future scope.
model OperationDocument {
  id              String                  @id @default(uuid()) @db.Uuid
  operationId     String                  @map("operation_id") @db.Uuid
  type            DocumentTemplateType
  number          String                  @db.VarChar(40)
  status          OperationDocumentStatus @default(DRAFT)
  storageKey      String?                 @unique @map("storage_key") @db.VarChar(255)
  mimeType        String?                 @map("mime_type") @db.VarChar(100)
  fileSize        Int?                    @map("file_size")
  renderedAt      DateTime?               @map("rendered_at") @db.Timestamptz(3)
  renderMetadata  Json?                   @map("render_metadata")
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)
  operation       Operation               @relation(fields: [operationId], references: [id], onDelete: Cascade)
  lifecycleEvents AssetLifecycleEvent[]

  @@unique([operationId, type])
  @@index([type, status])
  @@index([renderedAt])
  @@map("operation_documents")
}

model AssetLifecycleEvent {
  id          String                     @id @default(uuid()) @db.Uuid
  equipmentId String                     @map("equipment_id") @db.Uuid
  operationId String?                    @map("operation_id") @db.Uuid
  documentId  String?                    @map("document_id") @db.Uuid
  type        AssetLifecycleEventType
  occurredAt  DateTime                   @map("occurred_at") @db.Timestamptz(3)
  performedBy String?                    @map("performed_by") @db.Uuid
  description String                     @db.Text
  metadata    Json                       @default("{}")
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  equipment   Equipment                  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  operation   Operation?                 @relation(fields: [operationId], references: [id], onDelete: SetNull)
  document    OperationDocument?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  performer   User?                      @relation(fields: [performedBy], references: [id], onDelete: SetNull)
  attachments AssetLifecycleAttachment[]

  @@index([equipmentId, occurredAt], map: "asset_lifecycle_eq_at_idx")
  @@index([equipmentId, type, occurredAt], map: "asset_lifecycle_eq_type_at_idx")
  @@index([equipmentId, performedBy, occurredAt], map: "asset_lifecycle_eq_performer_at_idx")
  @@index([occurredAt, id], map: "asset_lifecycle_at_id_idx")
  @@index([operationId])
  @@index([documentId])
  @@index([documentId, type], map: "asset_lifecycle_doc_type_idx")
  @@index([type, occurredAt])
  @@index([performedBy, occurredAt])
  @@map("asset_lifecycle_events")
}

model AssetLifecycleAttachment {
  id               String              @id @default(uuid()) @db.Uuid
  eventId          String              @map("event_id") @db.Uuid
  storageKey       String              @unique @map("storage_key") @db.VarChar(255)
  originalFileName String              @map("original_file_name") @db.VarChar(255)
  mimeType         String              @map("mime_type") @db.VarChar(100)
  fileSize         Int                 @map("file_size")
  category         String              @db.VarChar(80)
  deletedAt        DateTime?           @map("deleted_at") @db.Timestamptz(3)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  event            AssetLifecycleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([deletedAt])
  @@map("asset_lifecycle_attachments")
}

model MaintenancePlan {
  id             String                 @id @default(uuid()) @db.Uuid
  equipmentId    String                 @map("equipment_id") @db.Uuid
  name           String                 @db.VarChar(140)
  description    String?                @db.Text
  type           MaintenancePlanType
  active         Boolean                @default(true)
  priority       MaintenancePriority    @default(MEDIUM)
  recurrenceRule Json                   @map("recurrence_rule")
  firstExecution DateTime               @map("first_execution") @db.Timestamptz(3)
  nextExecution  DateTime               @map("next_execution") @db.Timestamptz(3)
  lastExecution  DateTime?              @map("last_execution") @db.Timestamptz(3)
  createdBy      String?                @map("created_by") @db.Uuid
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  equipment      Equipment              @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  creator        User?                  @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  executions     MaintenanceExecution[]
  pmocPlan       PmocPlan?

  @@index([equipmentId, active])
  @@index([active, nextExecution])
  @@index([type, active])
  @@index([priority, nextExecution])
  @@map("maintenance_plans")
}

model MaintenanceExecution {
  id                String                     @id @default(uuid()) @db.Uuid
  maintenancePlanId String                     @map("maintenance_plan_id") @db.Uuid
  operationId       String?                    @unique @map("operation_id") @db.Uuid
  scheduledAt       DateTime                   @map("scheduled_at") @db.Timestamptz(3)
  executedAt        DateTime?                  @map("executed_at") @db.Timestamptz(3)
  status            MaintenanceExecutionStatus @default(PLANNED)
  notes             String?                    @db.Text
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  plan              MaintenancePlan            @relation(fields: [maintenancePlanId], references: [id], onDelete: Cascade)
  operation         Operation?                 @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@index([maintenancePlanId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([executedAt])
  @@map("maintenance_executions")
}

model PmocPlan {
  id                    String              @id @default(uuid()) @db.Uuid
  organizationId        String              @map("organization_id") @db.Uuid
  customerId            String              @map("customer_id") @db.Uuid
  equipmentId           String              @map("equipment_id") @db.Uuid
  maintenancePlanId     String              @unique @map("maintenance_plan_id") @db.Uuid
  responsibleTechnician String              @map("responsible_technician") @db.VarChar(150)
  artNumber             String?             @map("art_number") @db.VarChar(80)
  contractNumber        String?             @map("contract_number") @db.VarChar(80)
  startDate             DateTime            @map("start_date") @db.Date
  endDate               DateTime            @map("end_date") @db.Date
  active                Boolean             @default(true)
  observations          String?             @db.Text
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customer              Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipment             Equipment           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  maintenancePlan       MaintenancePlan     @relation(fields: [maintenancePlanId], references: [id], onDelete: Cascade)
  environments          PmocEnvironment[]
  equipments            PmocPlanEquipment[]

  @@index([customerId, active])
  @@index([equipmentId, active])
  @@index([organizationId, active])
  @@index([active, endDate])
  @@map("pmoc_plans")
}

model PmocEnvironment {
  id           String                     @id @default(uuid()) @db.Uuid
  pmocPlanId   String                     @map("pmoc_plan_id") @db.Uuid
  name         String                     @db.VarChar(140)
  area         String?                    @db.VarChar(80)
  occupancy    Int?
  observations String?                    @db.Text
  createdAt    DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)
  pmocPlan     PmocPlan                   @relation(fields: [pmocPlanId], references: [id], onDelete: Cascade)
  equipments   PmocEnvironmentEquipment[]

  @@index([pmocPlanId, name])
  @@map("pmoc_environments")
}

model PmocPlanEquipment {
  id          String    @id @default(uuid()) @db.Uuid
  pmocPlanId  String    @map("pmoc_plan_id") @db.Uuid
  equipmentId String    @map("equipment_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  pmocPlan    PmocPlan  @relation(fields: [pmocPlanId], references: [id], onDelete: Cascade)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([pmocPlanId, equipmentId])
  @@index([equipmentId])
  @@map("pmoc_plan_equipments")
}

model PmocEnvironmentEquipment {
  id            String          @id @default(uuid()) @db.Uuid
  environmentId String          @map("environment_id") @db.Uuid
  equipmentId   String          @map("equipment_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  environment   PmocEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  equipment     Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, equipmentId])
  @@index([equipmentId])
  @@map("pmoc_environment_equipments")
}

model Product {
  id                   String          @id @default(uuid()) @db.Uuid
  sku                  String          @unique @db.VarChar(80)
  internalCode         String?         @unique @map("internal_code") @db.VarChar(80)
  manufacturerCode     String?         @map("manufacturer_code") @db.VarChar(120)
  name                 String          @db.VarChar(180)
  unit                 String          @db.VarChar(20)
  brand                String?         @db.VarChar(120)
  model                String?         @db.VarChar(120)
  category             String?         @db.VarChar(120)
  technicalDescription String?         @map("technical_description") @db.Text
  weight               Decimal?        @db.Decimal(12, 3)
  dimensions           String?         @db.VarChar(120)
  isActive             Boolean         @default(true) @map("is_active")
  disabledAt           DateTime?       @map("disabled_at") @db.Timestamptz(3)
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  inventoryItems       InventoryItem[]
  operationParts       OperationPart[]

  @@index([name])
  @@index([category, isActive])
  @@index([brand])
  @@map("products")
}

model Supplier {
  id         String    @id @default(uuid()) @db.Uuid
  legalName  String    @map("legal_name") @db.VarChar(180)
  tradeName  String?   @map("trade_name") @db.VarChar(180)
  document   String?   @unique @db.VarChar(30)
  contacts   Json      @default("[]")
  address    Json      @default("{}")
  notes      String?   @db.Text
  isActive   Boolean   @default(true) @map("is_active")
  disabledAt DateTime? @map("disabled_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([legalName])
  @@index([tradeName])
  @@index([isActive])
  @@map("suppliers")
}

model InventoryItem {
  id                String          @id @default(uuid()) @db.Uuid
  organizationId    String          @map("organization_id") @db.Uuid
  productId         String          @map("product_id") @db.Uuid
  currentQuantity   Decimal         @default(0) @map("current_quantity") @db.Decimal(12, 3)
  minimumQuantity   Decimal         @default(0) @map("minimum_quantity") @db.Decimal(12, 3)
  idealQuantity     Decimal         @default(0) @map("ideal_quantity") @db.Decimal(12, 3)
  reservedQuantity  Decimal         @default(0) @map("reserved_quantity") @db.Decimal(12, 3)
  availableQuantity Decimal         @default(0) @map("available_quantity") @db.Decimal(12, 3)
  location          String?         @db.VarChar(160)
  isActive          Boolean         @default(true) @map("is_active")
  disabledAt        DateTime?       @map("disabled_at") @db.Timestamptz(3)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  movements         StockMovement[]
  operationParts    OperationPart[]

  @@index([organizationId, isActive])
  @@index([productId])
  @@index([availableQuantity])
  @@index([minimumQuantity])
  @@map("inventory_items")
}

model StockMovement {
  id              String            @id @default(uuid()) @db.Uuid
  inventoryItemId String            @map("inventory_item_id") @db.Uuid
  quantity        Decimal           @db.Decimal(12, 3)
  type            StockMovementType
  reason          String            @db.VarChar(255)
  operationId     String?           @map("operation_id") @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  occurredAt      DateTime          @map("occurred_at") @db.Timestamptz(3)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  inventoryItem   InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  operation       Operation?        @relation(fields: [operationId], references: [id], onDelete: SetNull)
  user            User              @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, occurredAt])
  @@index([type, occurredAt])
  @@index([operationId])
  @@index([userId, occurredAt])
  @@map("stock_movements")
}

model OperationPart {
  id              String        @id @default(uuid()) @db.Uuid
  operationId     String        @map("operation_id") @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  inventoryItemId String        @map("inventory_item_id") @db.Uuid
  quantity        Decimal       @db.Decimal(12, 3)
  notes           String?       @db.Text
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(3)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  operation       Operation     @relation(fields: [operationId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([operationId, deletedAt])
  @@index([productId])
  @@index([inventoryItemId])
  @@map("operation_parts")
}
