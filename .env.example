# Application
NODE_ENV=development
APP_NAME=ERP Operation API
APP_PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://erp_operation:change_me@postgres:5432/erp_operation?schema=public
POSTGRES_DB=erp_operation
POSTGRES_USER=erp_operation
POSTGRES_PASSWORD=change_me

# Authentication
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_characters
JWT_REFRESH_SECRET=replace_with_a_different_random_secret_of_at_least_32_characters
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000
JWT_ISSUER=erp-operation-api
JWT_AUDIENCE=erp-operation-clients

# Required only when running the one-time initial OWNER bootstrap.
OWNER_EMAIL=owner@example.com
OWNER_USERNAME=owner
OWNER_NAME=Proprietário da instalação
# Placeholder intentionally rejected by the bootstrap; replace before running prisma:seed.
OWNER_PASSWORD=replace_with_a_strong_password_of_at_least_12_characters

# Comma-separated exact origins. Wildcards are rejected.
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# JSON request limits in bytes. Operations need a larger, route-scoped limit because
# the existing contract accepts up to 16 PNG/JPEG data URLs of 5 MiB each.
HTTP_JSON_BODY_LIMIT_BYTES=1048576
OPERATION_JSON_BODY_LIMIT_BYTES=125829120

# Storage
STORAGE_PROVIDER=local
STORAGE_DRIVER=local
# Development may use ./storage. Production must use an absolute persistent mount, e.g. /app/storage.
STORAGE_PATH=./storage

# Global API throttling
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# Structured logging
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Frontend (Next.js) — Platform (/) e Operator (/operator) no mesmo serviço.
# ---------------------------------------------------------------------------
# Porta exposta pelo container do frontend (evita conflito com a API em :3000).
FRONTEND_PORT=4000
# URL da API acessada PELO NAVEGADOR (embutida no build do Next).
# Em produção, aponte para o domínio público da API (ex.: https://api.empresa.com.br/api/v1).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
